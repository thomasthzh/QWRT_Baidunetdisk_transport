#!/bin/sh
# Worker script for /etc/init.d/usb_swap
sleep 3

USB_DEV=/dev/sda1
USB_MP=/mnt/usbdata
USB_SWAP=/mnt/usbdata/.swap/swapfile
EMMC_SWAP=/dev/mmcblk0p26

swapoff "$EMMC_SWAP" 2>/dev/null
swapoff "$USB_SWAP" 2>/dev/null

if [ -b "$USB_DEV" ]; then
    mkdir -p "$USB_MP"
    mountpoint -q "$USB_MP" || mount "$USB_DEV" "$USB_MP" || return 0
    mkdir -p "$USB_MP/.swap"
    if [ ! -f "$USB_SWAP" ]; then
        dd if=/dev/zero of="$USB_SWAP" bs=1M count=2048
        chmod 0600 "$USB_SWAP"
        mkswap "$USB_SWAP"
    fi
    swapon "$USB_SWAP" -p 10 && logger -t usb_swap "USB swap activated: $USB_SWAP"
else
    logger -t usb_swap "USB not detected, falling back to eMMC swap"
    swapon "$EMMC_SWAP" && logger -t usb_swap "eMMC swap activated: $EMMC_SWAP"
fi
